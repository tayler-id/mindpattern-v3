{
    "platforms": {
        "bluesky": {
            "max_graphemes": 300,
            "require_url": true
        },
        "linkedin": {
            "max_chars": 3000,
            "require_url": false
        }
    },
    "banned_words": [
        "game-changer", "revolutionize", "disrupt", "synergy",
        "leverage", "paradigm", "ecosystem", "transformative",
        "cutting-edge", "best-in-class", "world-class"
    ],
    "banned_patterns": [
        "\u2014",
        "(?i)powered by mindpattern",
        "(?i)built with mindpattern",
        "(?i)mindpattern found",
        "(?i)mindpattern's agents",
        "(?i)try mindpattern",
        "(?i)built with my autonomous pipeline",
        "(?i)check out what mindpattern"
    ],
    "rate_limits": {
        "bluesky": {"max_posts_per_day": 3, "max_follows_per_day": 100},
        "linkedin": {"max_posts_per_day": 1, "max_follows_per_day": 50}
    },
    "reply_cooldown_days": 7,
    "posting": {
        "min_delay_seconds": 30,
        "jitter_range_seconds": [60, 300]
    }
}
