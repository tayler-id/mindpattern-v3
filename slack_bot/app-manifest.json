{
  "display_information": {
    "name": "MindPattern",
    "description": "Autonomous AI research pipeline — interactive Slack interface",
    "background_color": "#0a0f1a"
  },
  "features": {
    "bot_user": {
      "display_name": "MindPattern",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "channels:read",
        "reactions:write",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "message.channels"
      ]
    },
    "socket_mode_enabled": true,
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
